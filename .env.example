DATABASE_URL=postgresql://user:password@host:5432/moneytrack
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars_change_this
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars_change_this
OAUTH_EXCHANGE_SECRET=change_this_shared_secret_with_frontend
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PORT=5000
FRONTEND_URL=http://localhost:3000
APP_NAME=FinTrack

# Gmail SMTP for real OTP email delivery
# SMTP_PASS must be a Gmail App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail@gmail.com
SMTP_FROM_EMAIL=your_gmail@gmail.com
SMTP_FROM_NAME=FinTrack
SMTP_PASS=your_gmail_app_password

# SePay BankHub Sandbox
BANKHUB_API_BASE_URL=https://bankhub-api-sandbox.sepay.vn
BANKHUB_REQUEST_TIMEOUT_MS=20000
BANKHUB_USER_AGENT="MoneyTrack/1.0"
BANKHUB_CLIENT_ID=your_bankhub_client_id_from_sepay
BANKHUB_CLIENT_SECRET=your_bankhub_client_secret_from_sepay
BANKHUB_COMPANY_NAME="MoneyTrack Sandbox"
BANKHUB_COMPANY_XID=
BANKHUB_COMPLETION_REDIRECT_URI=
BANKHUB_LINK_COMPLETION_REDIRECT_URI=
SEPAY_BANKHUB_IPN_API_KEY=your_bankhub_ipn_api_key_if_configured

# System Bank configuration for SePay Link
SYSTEM_BANK_NAME=MBBank
SYSTEM_BANK_ACCOUNT=970400000000
SYSTEM_BANK_HOLDER="CONG TY CONG NGHE MONEYTRACK"
