# App
PORT=5000
APP_NAME=FinTrack
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fintrack_dev?schema=public
PRISMA_CONNECTION_LIMIT=1
PRISMA_POOL_TIMEOUT=30

# Auth
JWT_ACCESS_SECRET=replace_with_access_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_refresh_secret_min_32_chars
OAUTH_EXCHANGE_SECRET=replace_with_shared_oauth_exchange_secret

# Google/Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SendGrid Web API for OTP email
SENDGRID_API_KEY=replace_with_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@example.com
SENDGRID_FROM_NAME=FinTrack

# SMTP fallback env names still supported by the email service.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=replace_with_sendgrid_api_key
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=FinTrack

# SePay webhook
SEPAY_WEBHOOK_SECRET=replace_with_sepay_webhook_secret
SEPAY_BANKHUB_IPN_API_KEY=replace_with_bankhub_ipn_api_key

# BankHub Sandbox
BANKHUB_API_BASE_URL=https://bankhub-api-sandbox.sepay.vn
BANKHUB_CLIENT_ID=replace_with_bankhub_client_id
BANKHUB_CLIENT_SECRET=replace_with_bankhub_client_secret
BANKHUB_COMPANY_NAME=FinTrack Sandbox
BANKHUB_COMPANY_XID=replace_with_bankhub_company_xid
BANKHUB_USER_AGENT=FinTrack/1.0
BANKHUB_REQUEST_TIMEOUT_MS=15000

# Manual bank link fallback
SYSTEM_BANK_NAME=MBBank
SYSTEM_BANK_ACCOUNT=970400000000
SYSTEM_BANK_HOLDER=CONG TY CONG NGHE FINTRACK

FRONTEND_URL=
CORS_ORIGIN=
