DATABASE_URL=postgresql://user:password@host:5432/moneytrack
JWT_ACCESS_SECRET=your_access_secret_key_min_32_chars_change_this
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars_change_this
OAUTH_EXCHANGE_SECRET=change_this_shared_secret_with_frontend
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PORT=5000
FRONTEND_URL=http://localhost:3000
APP_NAME=FinTrack

# Gmail SMTP for real OTP email delivery
# SMTP_PASS must be a Gmail App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail@gmail.com
SMTP_FROM_EMAIL=your_gmail@gmail.com
SMTP_FROM_NAME=FinTrack
SMTP_PASS=your_gmail_app_password

# SePay BankHub Sandbox
BANKHUB_API_BASE_URL=https://bankhub-api-sandbox.sepay.vn
BANKHUB_CLIENT_ID=
BANKHUB_CLIENT_SECRET=
BANKHUB_COMPANY_NAME=
BANKHUB_COMPANY_XID=


